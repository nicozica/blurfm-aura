---
import QualitySelector from "./QualitySelector.astro";
import RecentlyPlayedPanel from "./RecentlyPlayedPanel.astro";
---

<main class="aura-app" id="aura-app" style="--artwork-url: url('/brand/cover-default.webp');">
  <div class="aura-stage">
    <header class="aura-header">
      <a href="/" class="aura-brand" aria-label="Blur FM Player">
        <img src="/brand/logo.svg" alt="Blur FM" />
      </a>

      <div class="aura-header-actions">
        <button
          type="button"
          class="header-action"
          id="recently-toggle"
          aria-expanded="false"
          aria-controls="recently-panel"
        >
          Recently played
        </button>
        <button
          type="button"
          class="header-action fullscreen-toggle"
          id="fullscreen-toggle"
          aria-pressed="false"
        >
          Full screen
        </button>
      </div>
    </header>

    <div class="aura-main-centered">
      <section class="player-layout">
        <figure class="cover-stage">
          <img
            id="cover-image"
            class="cover-image"
            src="/brand/cover-default.webp"
            alt="Current song cover"
            loading="eager"
          />
        </figure>

        <section class="player-main" aria-label="Blur FM live player">
          <p class="live-pill">
            <span class="live-dot" aria-hidden="true"></span>
            <span>Live on Air</span>
          </p>
          <h1 class="song-title" id="song-title">Loading song title...</h1>
          <p class="song-artist" id="song-artist">Please wait</p>

          <p class="song-extra" id="song-extra" hidden>
            <span id="song-album" hidden></span>
            <span id="song-extra-separator" hidden>•</span>
            <span id="song-year" hidden></span>
          </p>

          <div class="control-stack">
            <div class="primary-controls">
              <button
                type="button"
                class="play-toggle"
                id="play-toggle"
                aria-pressed="false"
                aria-label="Play"
              >
                <img
                  id="play-toggle-icon"
                  class="play-toggle-icon"
                  src="/brand/player-controls/btn-play.svg"
                  data-play-icon="/brand/player-controls/btn-play.svg"
                  data-stop-icon="/brand/player-controls/btn-stop.svg"
                  alt=""
                  aria-hidden="true"
                />
              </button>

              <QualitySelector />

              <div class="volume-control">
                <button
                  type="button"
                  class="volume-icon-btn"
                  id="volume-icon-btn"
                  aria-label="Mute"
                >
                  <img
                    id="volume-icon"
                    class="volume-icon"
                    src="/brand/volume-high.svg"
                    data-muted="/brand/volume-muted.svg"
                    data-low="/brand/volume-low.svg"
                    data-mid="/brand/volume-mid.svg"
                    data-high="/brand/volume-high.svg"
                    alt=""
                    aria-hidden="true"
                  />
                </button>
                <input
                  id="volume-slider"
                  class="volume-slider"
                  type="range"
                  min="0"
                  max="1"
                  step="0.01"
                  value="1"
                  aria-label="Volume"
                />
              </div>
            </div>
          </div>
        </section>
      </section>
    </div>
  </div>

  <RecentlyPlayedPanel />
  <audio id="audio-player" preload="none"></audio>
</main>

<script>
  import { initAuraPlayer } from "../scripts/player";

  initAuraPlayer();
</script>
