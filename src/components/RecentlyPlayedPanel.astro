<div class="recently-modal" id="recently-modal" hidden>
  <button
    type="button"
    class="recently-overlay"
    id="recently-overlay"
    aria-label="Close recently played panel"
  ></button>

  <section class="recently-panel" id="recently-panel" aria-live="polite" role="dialog" aria-modal="true">
    <div class="recently-panel-head">
      <h2>Recently played</h2>
    </div>
    <p class="recently-empty" id="recently-empty">This list fills as songs change.</p>
    <ul class="recently-list" id="recently-list"></ul>
  </section>
</div>
